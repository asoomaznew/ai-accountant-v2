# Copy to .env and fill in. NEVER commit real values.
# Frontend (browser-exposed): only put non-secret / dev values here.
VITE_BACKEND_URL=http://localhost:8000
# For production, set a real token; the app will NOT use the dev bypass token when built.
VITE_BACKEND_TOKEN=
# WARNING: exposing the Gemini key to the browser is insecure. Prefer proxying via backend.
VITE_GEMINI_API_KEY=

# Dataset generator (server-side only):
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
